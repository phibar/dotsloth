{
  "name": "@phibar/dotsloth",
  "description": "Sync your dots, be a sloth - Dev environment sync CLI for macOS",
  "version": "0.0.1",
  "author": "phibar",
  "bin": {
    "dotsloth": "./bin/run.js",
    ".sloth": "./bin/run.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": "https://github.com/phibar/dotsloth/issues",
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "chalk": "^5",
    "enquirer": "^2",
    "zod": "^3"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^10",
    "oclif": "^4",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/phibar/dotsloth",
  "keywords": [
    "oclif",
    "dotfiles",
    "macos",
    "icloud",
    "sync",
    "cli",
    "git",
    "ssh",
    "keychain"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "dotsloth",
    "dirname": "dotsloth",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ],
    "topicSeparator": " ",
    "topics": {
      "env": {
        "description": "Manage .env files across projects with iCloud sync"
      },
      "org": {
        "description": "Manage GitHub organizations and git identities"
      },
      "secret": {
        "description": "Manage secrets in macOS Keychain"
      }
    }
  },
  "repository": "phibar/dotsloth",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md"
  },
  "types": "dist/index.d.ts"
}
